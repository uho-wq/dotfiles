  "hooks": {
    "SessionStart": [],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/git/dotfiles/claudecode/hooks/save-memory.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/git/dotfiles/claudecode/hooks/notify-stop.sh"
          }
        ]
      }
    ],
    "Notification": []
  },
  "statusLine": {
    "type": "command",
    "command": "npx ccusage@latest statusline"
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "dig@kuu-marketplace": true,
    "code-review@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "team-review@local": true
  },
  "language": "日本語",
  "effortLevel": "high",
  "autoUpdatesChannel": "latest",
  "tui": "default",
  "autoMemoryEnabled": true,
  "autoDreamEnabled": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
